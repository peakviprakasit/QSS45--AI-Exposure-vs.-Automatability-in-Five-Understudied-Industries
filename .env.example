# LinkedIn credentials (required for scraping)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password_here

# Indeed base URL (no credentials needed, but set your locale)
INDEED_BASE_URL=https://www.indeed.com

# Glassdoor credentials (optional third fallback)
GLASSDOOR_EMAIL=your_email@example.com
GLASSDOOR_PASSWORD=your_password_here

# Wayback Machine CDX API (no key required, but set rate limit)
WAYBACK_RATE_LIMIT_SECONDS=2

# Random seed for reproducibility
RANDOM_SEED=42

# Chrome driver path (leave blank to use system PATH)
CHROMEDRIVER_PATH=
